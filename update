#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

# shellcheck source=lib/common.sh
source "$ROOT/lib/common.sh"

ensure_script_permissions "$ROOT"
require_not_root

OLD_UPDATE="$(git rev-parse HEAD:update 2>/dev/null || echo none)"
git pull --ff-only || rosne_warn "git pull failed for rosnebot-setup"
NEW_UPDATE="$(git rev-parse HEAD:update 2>/dev/null || echo none)"

if [ "$OLD_UPDATE" != "$NEW_UPDATE" ]; then
    rosne_info "Update script changed — re-running..."
    exec "$ROOT/update" "$@"
fi

if [ -d ./temprosnehook ] && [ ! -d ./rosnehook ]; then
    mv temprosnehook rosnehook
fi

if [ ! -d ./rosnehook ]; then
    rosne_die "rosnehook/ missing — run ./install-rosnebots first"
fi

pushd rosnehook >/dev/null
git remote set-url origin https://github.com/Scp079TheOldAi/rosnehook.git 2>/dev/null || true
git pull --ff-only || rosne_warn "rosnehook git pull failed"
git submodule sync --recursive
git submodule update --init --recursive
[ -x ./scripts/copy-libvstdlib.sh ] && ./scripts/copy-libvstdlib.sh || true
popd >/dev/null

rosne_info "Rebuilding rosnehook..."
build_rosnehook_textmode "$ROOT"

pushd rosnehook-ipc-server >/dev/null
git remote set-url origin https://github.com/Scp079TheOldAi/rosnehook-ipc-server.git 2>/dev/null || true
bash update.sh
popd >/dev/null

pushd vacbypass-modules >/dev/null
git pull --ff-only || true
mkdir -p build && pushd build >/dev/null
cmake .. && make -j"$(cpu_count)"
sudo cp -r bin64 /opt/ 2>/dev/null || rosne_warn "Could not copy bin64 to /opt/"
popd >/dev/null; popd >/dev/null

pushd rosnehook-ipc-web-panel >/dev/null
git remote set-url origin https://github.com/Scp079TheOldAi/rosnehook-ipc-web-panel.git 2>/dev/null || true
bash update.sh
popd >/dev/null

install_navmeshes
rosne_ok "Update complete."