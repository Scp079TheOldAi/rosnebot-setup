#!/usr/bin/env bash
# Install Rosnebot stack: rosnehook, vacbypass-modules, IPC, web panel.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

# shellcheck source=lib/common.sh
source "$ROOT/lib/common.sh"
rosne_trap_errors

ensure_script_permissions "$ROOT"
require_not_root
require_git_repo

rosne_set_step "Rosnebot setup — installing components"

if ! install_system_deps; then
    rosne_warn "Automatic dependency install skipped or failed — checking required tools..."
fi

require_cmd touch "coreutils"
require_cmd git "git"
require_cmd cmake "cmake (build-essential / base-devel)"
require_cmd make "make"
require_cmd g++ "g++ (build-essential / base-devel)"
require_cmd curl "curl"
require_cmd rsync "rsync"
require_cmd npm "nodejs npm"
require_cmd firejail "firejail"
require_cmd pgrep "procps"

if ! command -v route >/dev/null 2>&1 && [ ! -x /sbin/route ]; then
    rosne_die "route not found — install net-tools (see README)"
fi

rosne_set_step "Removing legacy catbot-setup files"
[ -x ./remove-legacy ] && ./remove-legacy || true

# Legacy folder name from older installs
if [ -d ./temprosnehook ] && [ ! -d ./rosnehook ]; then
    rosne_warn "Renaming temprosnehook/ -> rosnehook/"
    mv temprosnehook rosnehook
fi

# Legacy vac bypass repo name
if [ -d ./just-disable-vac ] && [ ! -d ./vacbypass-modules ]; then
    rosne_warn "Renaming just-disable-vac/ -> vacbypass-modules/"
    mv just-disable-vac vacbypass-modules
fi

clone_or_pull "https://github.com/Scp079TheOldAi/rosnehook.git" "rosnehook" true
mkdir -p user_instances

if [ ! -f /opt/rosnehook/bin/librosnehook-textmode.so ]; then
    build_rosnehook_textmode "$ROOT"
else
    rosne_ok "rosnehook textmode binary already installed in /opt/rosnehook/bin/"
fi

if [ ! -d ./vacbypass-modules/build/bin64/libvpcfs.so.0 ]; then
    clone_or_pull "https://github.com/Scp079TheOldAi/vacbypass-modules.git" "vacbypass-modules" false
    pushd vacbypass-modules >/dev/null
    mkdir -p build && pushd build >/dev/null
    cmake .. || rosne_die "vacbypass-modules cmake failed"
    make -j"$(cpu_count)" || rosne_die "vacbypass-modules build failed"
    popd >/dev/null; popd >/dev/null
    rosne_ok "Built vacbypass-modules"
fi

if [ ! -d ./rosnehook-ipc-server ]; then
    clone_or_pull "https://github.com/Scp079TheOldAi/rosnehook-ipc-server.git" "rosnehook-ipc-server" true
    pushd rosnehook-ipc-server >/dev/null
    bash ./install.sh || rosne_die "rosnehook-ipc-server install failed"
    popd >/dev/null
fi

if [ ! -d ./rosnehook-ipc-web-panel ]; then
    clone_or_pull "https://github.com/Scp079TheOldAi/rosnehook-ipc-web-panel.git" "rosnehook-ipc-web-panel" true
    pushd rosnehook-ipc-web-panel >/dev/null
    bash ./update.sh || rosne_die "rosnehook-ipc-web-panel update failed"
    popd >/dev/null
fi

mkdir -p ./rosnehook-ipc-web-panel/logs
touch ./rosnehook-ipc-web-panel/logs/main.log 2>/dev/null || true

if [ -f /etc/firejail/firejail.config ]; then
    rosne_set_step "Adjusting firejail restricted-network"
    sudo sed -i 's/^restricted-network yes/# restricted-network yes/g' /etc/firejail/firejail.config 2>/dev/null || \
        rosne_warn "Could not edit /etc/firejail/firejail.config — check firejail manually"
fi

install_navmeshes

echo
rosne_ok "Rosnebot setup complete."
echo
echo "  Start panel:  ./start"
echo "  Update all:   ./update"
echo "  Accounts:     create accounts.txt in this folder (USERNAME:PASSWORD per line)"
echo